rule "Primo VE Display - Description 300"
	when
        MARC is "300"."a"
	then
        set TEMP"1" to MARC."300" sub without sort "a"
        add prefix (TEMP"1","$$C300_label$$V")
        create pnx."display"."description" with TEMP"1"
end

