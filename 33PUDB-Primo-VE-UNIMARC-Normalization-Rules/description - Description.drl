        set TEMP"1" to MARC."333" sub without sort "a"
        add prefix (TEMP"1","$$C333_label$$V")
        create pnx."display"."description" with TEMP"1"
end

rule "Primo VE Display - Description 334"
	when
        MARC."334" has any "a,b,c,d"
	then
        set TEMP"1" to MARC."334" sub without sort "a,b,c,d" wrap subfields
        replace wrapping delimiters (TEMP"1","a","","")  
        replace wrapping delimiters (TEMP"1","b"," - ","") 
        replace wrapping delimiters (TEMP"1","c"," - ","") 
        replace wrapping delimiters (TEMP"1","d"," - ","") 
        add prefix (TEMP"1","$$C334_label$$V")
        create pnx."display"."description" with TEMP"1"
end

